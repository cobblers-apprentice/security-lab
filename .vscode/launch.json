{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Security Lab (.NET)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/SecurityLab.Api/bin/Debug/net10.0/SecurityLab.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/SecurityLab.Api",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_URLS": "http://localhost:5080",
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "console": "internalConsole"
    }
  ]
}
